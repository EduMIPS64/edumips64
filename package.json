{
  "name": "edumips64-webui",
  "version": "1.0.0",
  "description": "The web UI for EduMIPS64 (web.edumips.org). Depends on the web worker implementation of the EduMIPS64 core (worker.js).",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "build-dbg": "vite build --mode development",
    "build": "vite build",
    "test": "npx playwright test",
    "test:unit": "vitest run",
    "test:coverage": "COVERAGE=true npm run build-dbg && COVERAGE=true npx playwright test",
    "report:coverage": "nyc report --reporter=lcov --reporter=text",
    "electron": "electron electron/electron_main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format --write ."
  },
  "keywords": [],
  "author": "Andrea Spadaccini",
  "license": "GPL-2.0-or-later",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@microsoft/applicationinsights-web": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "express": "^5.2.1",
    "lodash": "^4.17.19",
    "monaco-editor": "0.55.1",
    "monaco-vim": "^0.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@electron/packager": "^20.0.0",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "0.23.1",
    "nyc": "^18.0.0",
    "playwright": "1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  }
}
