{
  "name": "edumips64-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/universal:6",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    },
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack", "mathematic.vscode-pdf"]
    }
  },
  "postCreateCommand": "bash -i -c './gradlew --version && nvm install && npm install && npx playwright install --with-deps'"
}
